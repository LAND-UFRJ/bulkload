# Dependencies
node_modules/
jspm_packages/

# TypeScript v1 declaration files
# typings/ # generally not needed for modern TS

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Optional REPL history
.node_repl_history

# Environment variables
.env
.env.*
# keep an example file tracked (remove the "!" if you don't want this)
!.env.example 

# Compiled/Build files (adjust as needed for your specific build folder, e.g., "dist" or "build")
/build
/dist
*.js.map # Source maps
*.d.ts # TypeScript declaration maps
# If you run TS files directly with ts-node, you might need to ignore generated .js files too,
# but typically you'd ignore the entire build output directory.

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# OS and Editor files
.DS_Store # macOS
.vscode/ # VS Code configuration (optional, if you want to share workspace settings)
.cache/ # Parcel cache
.nyc_output # nyc test coverage
coverage # Istanbul test coverage

# Yarn Integrity file
.yarn-integrity

# Output of 'npm pack'
*.tgz

# Next.js build output
.next/

# Nuxt.js build output
.nuxt/

# VuePress build output
.vuepress/dist/

# Serverless directories
.serverless/

